# ═══════════════════════════════════════════════════
#  Building Field Management — 환경변수 템플릿
#  사용법:  cp .env.example .env  후 아래 값들을 채우세요.
#  ⚠️ 이 파일(.env.example)에는 절대 실제 키를 넣지 마세요. (git에 올라감)
# ═══════════════════════════════════════════════════

# ── 로컬 PostgreSQL (NAS Docker) ─────────────────────
# NAS docker-compose 의 POSTGRES_PASSWORD 와 동일하게 설정
POSTGRES_PASSWORD=원하는_DB_비밀번호
DATABASE_URL=postgresql://fielduser:원하는_DB_비밀번호@postgres:5432/fieldmanagement
DIRECT_URL=postgresql://fielduser:원하는_DB_비밀번호@postgres:5432/fieldmanagement

# ── Supabase (실제 데이터 저장소) ─────────────────────
# URL 은 프로젝트 API URL (https://xxxx.supabase.co) — 대시보드 주소 아님!
NEXT_PUBLIC_SUPABASE_URL=https://프로젝트ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=supabase_anon_public_key

# ── AI API 키 ────────────────────────────────────────
# Gemini(문서 OCR·장비 인식): aistudio.google.com → Get API key (AIza... 형식)
GOOGLE_GENERATIVE_AI_API_KEY=AIza로_시작하는_Gemini_키
# Anthropic(선택): console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-로_시작하는_키

# ── Google Drive/Sheets 연계 ─────────────────────────
# 서비스 계정 이메일을 Drive 폴더/마스터 시트에 뷰어 이상으로 공유하세요.
GOOGLE_SERVICE_ACCOUNT_EMAIL=field-sync@project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_WORKER_MASTER_SPREADSHEET_ID=노무관리_마스터_시트_ID
GOOGLE_WORKER_MASTER_SHEET_NAME=근로자마스터
GOOGLE_BILLING_OUTPUT_FOLDER_ID=월별투입명세_출력_폴더_ID
GOOGLE_WORKER_DOC_PENDING_FOLDER_ID=신규스캔_대기_폴더_ID
GOOGLE_WORKER_DOC_COMPLETED_FOLDER_ID=분류완료_마스터_폴더_ID
GOOGLE_WORKER_DOC_FAILED_FOLDER_ID=처리실패_검토_폴더_ID

# ── 웹 푸시 (VAPID) ──────────────────────────────────
# 생성: npx web-push generate-vapid-keys  (public/private 한 쌍)
VAPID_PUBLIC_KEY=VAPID_공개키
NEXT_PUBLIC_VAPID_PUBLIC_KEY=VAPID_공개키와_동일
VAPID_PRIVATE_KEY=VAPID_비밀키
# 매일 알림 발송 API 호출용 시크릿(아무 문자열)
REMINDER_SECRET=임의의_시크릿_문자열

# ── Next.js ──────────────────────────────────────────
# 생성: openssl rand -hex 32
NEXTAUTH_SECRET=무작위_32바이트_hex
# 서버 세션 서명용. NEXTAUTH_SECRET 과 동일한 값을 써도 됩니다.
SESSION_SECRET=무작위_32바이트_hex
# 실제 접속 주소 (HTTPS 권장)
NEXTAUTH_URL=https://field.example.duckdns.org
