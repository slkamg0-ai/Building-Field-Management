# Building Field Management 환경변수 예시
# 사용법: 이 파일을 .env로 복사한 뒤 실제 값을 채우세요.
# 주의: .env에는 비밀번호/API 키가 들어가므로 GitHub에 올리면 안 됩니다.

# PostgreSQL
POSTGRES_PASSWORD=원하는_DB_비밀번호
DATABASE_URL=postgresql://fielduser:원하는_DB_비밀번호@postgres:5432/fieldmanagement
DIRECT_URL=postgresql://fielduser:원하는_DB_비밀번호@postgres:5432/fieldmanagement

# Next.js / 세션
SESSION_SECRET=openssl_rand_hex_32_같은_긴_랜덤값
NEXTAUTH_SECRET=SESSION_SECRET과_같은_값을_써도_됩니다
NEXTAUTH_URL=https://field.example.duckdns.org

# AI 문서 인식: Google AI Studio에서 발급
GOOGLE_GENERATIVE_AI_API_KEY=AIza로_시작하는_Gemini_API_키
GOOGLE_GEMINI_API_KEY=AIza로_시작하는_Gemini_API_키

# Google Drive/Sheets 인증 방식 A: OAuth 권장
# 서비스 계정 키 생성이 보안정책으로 막힌 경우 이 방식을 사용하세요.
GOOGLE_OAUTH_CLIENT_ID=구글_OAuth_클라이언트_ID
GOOGLE_OAUTH_CLIENT_SECRET=구글_OAuth_클라이언트_시크릿
GOOGLE_OAUTH_REFRESH_TOKEN=구글_OAuth_refresh_token

# Google Drive/Sheets 인증 방식 B: 서비스 계정
# 조직 정책상 서비스 계정 키 생성이 허용되는 경우만 사용하세요.
GOOGLE_SERVICE_ACCOUNT_EMAIL=field-sync@project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Drive/Sheets 대상
GOOGLE_WORKER_MASTER_SPREADSHEET_ID=노무관리_마스터_시트_ID
GOOGLE_WORKER_MASTER_SHEET_NAME=근로자마스터
GOOGLE_BILLING_OUTPUT_FOLDER_ID=월별투입명세_출력_폴더_ID
GOOGLE_WORKER_DOC_PENDING_FOLDER_ID=신규스캔_대기_폴더_ID
GOOGLE_WORKER_DOC_COMPLETED_FOLDER_ID=분류완료_마스터_폴더_ID
GOOGLE_WORKER_DOC_FAILED_FOLDER_ID=처리실패_검토_폴더_ID

# 푸시 알림
VAPID_PUBLIC_KEY=VAPID_공개키
NEXT_PUBLIC_VAPID_PUBLIC_KEY=VAPID_공개키와_같은_값
VAPID_PRIVATE_KEY=VAPID_비밀키
REMINDER_SECRET=알림_API_호출용_긴_랜덤값
